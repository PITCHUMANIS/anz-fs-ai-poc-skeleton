# Copy to .env for local experiments. Defaults work offline with MOCK provider.
POC_PROVIDER=mock
POC_MODEL_ID=mock-fs-assist-v1
POC_REGION=australia-east
POC_MIN_RETRIEVAL_SCORE=0.15
# Set true to simulate an unavailable model endpoint and exercise degraded mode.
POC_FORCE_DEGRADED=false
POC_AUDIT_DIR=.audit
